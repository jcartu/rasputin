{
  "name": "alfie-tests",
  "version": "1.0.0",
  "description": "Comprehensive E2E test suite proving ALFIE superiority over MANUS - 100+ tests",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:api": "playwright test --project=api",
    "test:stress": "playwright test --project=stress",
    "test:performance": "playwright test --project=performance",
    "test:ai": "playwright test tests/ai/",
    "test:realtime": "playwright test tests/realtime/",
    "test:integrations": "playwright test tests/integrations/",
    "test:ui-tests": "playwright test tests/ui/",
    "test:dataviz": "playwright test tests/dataviz/",
    "test:platform": "playwright test tests/platform/",
    "test:enterprise": "playwright test tests/enterprise/",
    "test:manus-killer": "playwright test tests/manus-killer/",
    "test:visual": "playwright test tests/visual/",
    "test:visual:update": "playwright test tests/visual/ --update-snapshots",
    "test:parallel": "playwright test --workers=8",
    "test:ci": "playwright test --reporter=github,html,json",
    "report": "playwright show-report reports/html",
    "report:generate": "playwright test --reporter=html",
    "clean": "rm -rf reports test-results data",
    "setup": "playwright install --with-deps"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.0",
    "ws": "^8.19.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
