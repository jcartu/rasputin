  },
  "routing_rules": [
    {
      "pattern": "code|program|function|debug|fix|implement",
      "model": "code",
      "priority": 1
    },
    {
      "pattern": "image|screenshot|picture|photo|visual",
      "model": "vision",
      "priority": 1
    },
    {
      "pattern": "quick|simple|what is|define|list",
      "model": "fast",
      "priority": 2
    },
    {
      "pattern": ".*",
      "model": "primary",
      "priority": 99
    }
  ],
